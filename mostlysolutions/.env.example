# EmailJS — get these from https://emailjs.com (free, 200 emails/month)
#
# 1. Create account → Email Services → connect Gmail/Outlook
# 2. Email Templates → create two templates (owner notification + customer confirmation)
# 3. Account → API Keys → copy your Public Key

NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_OWNER=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_CUSTOMER=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# --- EmailJS template variables to use in your templates ---
# {{from_name}}       — customer full name
# {{from_email}}      — customer email  (set as Reply-To in owner template)
# {{phone}}           — customer phone
# {{vehicle_reg}}     — vehicle registration plate
# {{service_type}}    — selected service
# {{preferred_date}}  — preferred appointment date
# {{notes}}           — additional notes
